# ─── Toronto Bylaw Guide — example environment ───────────────────────────────
# Copy to .env.local and fill in. Never commit real keys.
# All keys below are read SERVER-SIDE only and are never exposed to the browser.

# Optional Postgres (the app works without it — feedback/logs go to console).
DATABASE_URL=

# ── V6 general AI (OpenAI-compatible): Ask RAG, photo review, plant ID prompt ──
# If unset, AI features fall back to the existing source-based behaviour.
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_VISION_MODEL=gpt-4o-mini
AI_TEXT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── V6.1 Plant.id species identification (separate from OpenAI) ───────────────
# Used only by the Prohibited Plants photo identifier. If unset, the upload
# feature falls back gracefully and the manual identifier still works.
# Plant.id is operated by Kindwise. Product: https://www.kindwise.com/plant-id
# Get an API key at https://admin.kindwise.com
PLANT_ID_API_KEY=

# ── V6.6 Feedback email notification (server-side only) ───────────────────────
# When configured, a notification email is sent to FEEDBACK_TO_EMAIL each time a
# user submits the Feedback form. If neither provider is set, feedback is still
# received/stored and the user sees a graceful "notification could not be sent"
# note. See EMAIL_SETUP.md. NEVER prefix any of these with NEXT_PUBLIC.
FEEDBACK_TO_EMAIL=info@bylawguide.ca

# Option A — SMTP (e.g. the bylawguide.ca mailbox via your host). Preferred when
# you have working SMTP credentials for the domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BylawGuide Feedback <info@bylawguide.ca>

# Option B — Resend (transactional email; better deliverability from a verified
# domain). If RESEND_API_KEY is set it takes precedence over SMTP.
RESEND_API_KEY=
RESEND_FROM_EMAIL=BylawGuide Feedback <noreply@bylawguide.ca>
