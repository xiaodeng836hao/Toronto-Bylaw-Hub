# ─── Toronto Bylaw Guide — example environment ───────────────────────────────
# Copy to .env.local and fill in. Never commit real keys.
# All keys below are read SERVER-SIDE only and are never exposed to the browser.

# Optional Postgres (the app works without it — feedback/logs go to console).
DATABASE_URL=

# ── V6 general AI (OpenAI-compatible): Ask RAG, photo review, plant ID prompt ──
# If unset, AI features fall back to the existing source-based behaviour.
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_VISION_MODEL=gpt-4o-mini
AI_TEXT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── V6.1 Plant.id species identification (separate from OpenAI) ───────────────
# Used only by the Prohibited Plants photo identifier. If unset, the upload
# feature falls back gracefully and the manual identifier still works.
# Plant.id is operated by Kindwise. Product: https://www.kindwise.com/plant-id
# Get an API key at https://admin.kindwise.com
PLANT_ID_API_KEY=
