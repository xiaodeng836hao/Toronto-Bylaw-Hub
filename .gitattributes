# Normalize line endings across platforms.
# Text files are stored with LF in the repository and checked out with LF on
# every OS, so Windows / macOS / Linux don't produce spurious whitespace diffs.
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# SVG is XML text.
*.svg   text eol=lf
