generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BylawChapter {
  id                   String   @id @default(cuid())
  chapterNumber        String   @unique
  title                String
  plainLanguageSummary String
  category             String
  officialUrl          String?
  pdfUrl               String?
  tags                 String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Feedback {
  id           String   @id @default(cuid())
  email        String?
  userType     String
  feedbackType String
  feature      String?
  message      String
  canContact   Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model PhotoAnalysis {
  id              String   @id @default(cuid())
  imageUrl        String?
  detectedIssue   String?
  relevantChapter String?
  relevantSection String?
  confidence      String?
  createdAt       DateTime @default(now())
}

model ChecklistItem {
  id          String  @id @default(cuid())
  title       String
  description String
  category    String
  isRequired  Boolean @default(true)
}

// ── V6 RAG + AI models (optional; used only when DATABASE_URL is configured) ──
// Dev/default uses a local JSON vector store (data/rag/index.json). For
// production pgvector, switch `RagChunk.embedding` to a vector column — see
// RAG_SOURCE_MAINTENANCE.md.

model RagSource {
  id          String   @id @default(cuid())
  title       String
  type        String
  officialUrl String?
  internalUrl String?
  description String?
  lastReviewed String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chunks      RagChunk[]
}

model RagChunk {
  id           String    @id @default(cuid())
  sourceId     String?
  source       RagSource? @relation(fields: [sourceId], references: [id])
  chapter      String?
  section      String?
  sectionTitle String?
  text         String
  // Embeddings stored as JSON for the dev fallback; use pgvector in production.
  embedding    Json?
  metadataJson Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AskQueryLog {
  id                 String   @id @default(cuid())
  query              String
  answerSummary      String?
  retrievedSourceIds String[]
  confidence         String?
  createdAt          DateTime @default(now())
}

model AIImageAnalysis {
  id              String   @id @default(cuid())
  type            String   // "photo-review" | "plant-identification"
  selectedCategory String?
  resultJson      Json?
  createdAt       DateTime @default(now())
}

// V6.1 — optional Plant.id result log. The feature is stateless by default
// (no persistence); raw uploaded images are never stored.
model PlantIdentificationLog {
  id                   String   @id @default(cuid())
  normalizedResultJson Json?
  prohibitedMatchesJson Json?
  selectedSeason       String?
  selectedLocationType String?
  createdAt            DateTime @default(now())
}
